# Copy to .env.local or configure these names in the hosting platform.
# Generate secrets locally; never commit generated values.
APP_JWT_HMAC_SECRET=
APP_CREDENTIAL_ENCRYPTION_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Optional local-only shared login. Disabled unless explicitly enabled.
APP_SHARED_LOCALHOST_LOGIN_ENABLED=false
APP_SHARED_LOCALHOST_TENANT_ADMIN_EMAIL=
APP_SHARED_LOCALHOST_TENANT_ADMIN_PASSWORD_HASH=
